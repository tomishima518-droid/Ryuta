<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Ultimate Online Craft</title>
    <script src="https://cdn.jsdelivr.net/npm/gun/gun.js"></script>
    <script type="importmap">
    {
        "imports": {
            "three": "https://unpkg.com/three@0.150.1/build/three.module.js"
        }
    }
    </script>
    <style>
        body { margin: 0; overflow: hidden; font-family: 'Courier New', Courier, monospace; user-select: none; touch-action: none; background: #000; }
        canvas { display: block; }
        
        /* UIレイヤー */
        #ui-overlay { position: fixed; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0,0,0,0.8); z-index: 100; color: white; }
        #hotbar { position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); display: flex; gap: 5px; background: rgba(0,0,0,0.5); padding: 5px; border: 2px solid #555; }
        .slot { width: 40px; height: 40px; border: 2px solid #888; display: flex; align-items: center; justify-content: center; font-size: 10px; position: relative; }
        .slot.active { border-color: #fff; background: rgba(255,255,255,0.2); }
        
        /* Roblox風ステータス */
        #stats { position: absolute; bottom: 70px; left: 50%; transform: translateX(-50%); width: 300px; }
        .bar-container { width: 100%; height: 12px; background: #333; border: 2px solid #000; margin-bottom: 4px; overflow: hidden; }
        #hp-bar { background: #ff4d4d; width: 100%; height: 100%; transition: 0.3s; }
        #hunger-bar { background: #ffa500; width: 90%; height: 100%; transition: 0.3s; }
        #exp-bar { position: absolute; bottom: 0; left: 0; width: 0%; height: 5px; background: #45ff45; box-shadow: 0 0 10px #45ff45; }

        /* モバイル操作 */
        #joystick-zone { position: absolute; bottom: 40px; left: 40px; width: 120px; height: 120px; background: rgba(255,255,255,0.1); border-radius: 50%; border: 2px solid #fff; display: none; }
        #joystick-stick { position: absolute; top: 35px; left: 35px; width: 50px; height: 50px; background: rgba(255,255,255,0.4); border-radius: 50%; }
        #action-btns { position: absolute; bottom: 40px; right: 40px; display: none; flex-direction: column; gap: 10px; }
        .m-btn { width: 70px; height: 70px; background: rgba(255,255,255,0.2); border: 2px solid #fff; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; }
        
        #crosshair { position: absolute; top: 50%; left: 50%; width: 16px; height: 16px; border: 2px solid #fff; transform: translate(-50%, -50%); pointer-events: none; border-radius: 50%; }
        #player-list { position: absolute; top: 10px; left: 10px; color: #45ff45; font-size: 12px; background: rgba(0,0,0,0.5); padding: 5px; }
    </style>
</head>
<body>

<div id="ui-overlay">
    <h1>ULTIMATE CRAFT</h1>
    <input type="text" id="username" placeholder="名前を入力" style="padding:15px; font-size:20px; text-align:center; margin-bottom:10px;">
    <button onclick="initGame()" style="padding:15px 40px; font-size:22px; background:#2ecc71; color:white; border:none; cursor:pointer; font-weight:bold;">ワールドに参加</button>
</div>

<div id="player-list">ONLINE: 1</div>
<div id="crosshair"></div>

<div id="stats">
    <div class="bar-container"><div id="hp-bar"></div></div>
    <div class="bar-container"><div id="hunger-bar"></div></div>
</div>
<div id="exp-bar"></div>

<div id="hotbar">
    <div class="slot active" data-id="1">草</div>
    <div class="slot" data-id="2">石</div>
    <div class="slot" data-id="3">木</div>
    <div class="slot" data-id="4">土</div>
    <div class="slot" data-id="5">金</div>
</div>

<div id="joystick-zone"><div id="joystick-stick"></div></div>
<div id="action-btns">
    <div class="m-btn" id="btn-jump">JUMP</div>
    <div class="m-btn" id="btn-action">PLACE</div>
</div>

<script type="module">
    import * as THREE from 'three';

    // --- グローバル変数 ---
    let scene, camera, renderer, gun, world;
    let myId = "p_" + Math.random().toString(36).substr(2, 9);
    let players = {};
    let blocks = [];
    let selectedBlockType = 1;
    let moveFwd = 0, moveRight = 0, vY = 0;
    let lon = 0, lat = 0;
    
    const blockTypes = {
        1: { name: 'Grass', color: 0x4d8a31 },
        2: { name: 'Stone', color: 0x808080 },
        3: { name: 'Wood', color: 0x8B4513 },
        4: { name: 'Dirt', color: 0x5C4033 },
        5: { name: 'Gold', color: 0xFFD700 }
    };

    window.initGame = () => {
        const name = document.getElementById('username').value || "Steve";
        document.getElementById('ui-overlay').style.display = 'none';
        if('ontouchstart' in window) {
            document.getElementById('joystick-zone').style.display = 'block';
            document.getElementById('action-btns').style.display = 'flex';
        }
        setupThree();
        setupNetworking(name);
        animate();
    };

    function setupThree() {
        scene = new THREE.Scene();
        scene.background = new THREE.Color(0x87CEEB);
        camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        
        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        document.body.appendChild(renderer.domElement);

        const light = new THREE.HemisphereLight(0xffffff, 0x444444, 1.2);
        scene.add(light);

        // 初期の地面
        const geo = new THREE.BoxGeometry(1, 1, 1);
        for(let x=-8; x<8; x++) {
            for(let z=-8; z<8; z++) {
                addBlock(x, 0, z, 1, false);
            }
        }
        camera.position.set(0, 2, 5);
    }

    function setupNetworking(name) {
        // Gun.js の無料シグナリングサーバーを利用（自動同期）
        gun = Gun(['https://gun-manhattan.herokuapp.com/gun']);
        world = gun.get('craft-world-shared-v1');

        // 他人の動きを受信
        world.get('players').map().on((data, id) => {
            if(!data || id === myId) return;
            if(!players[id]) {
                const pGeo = new THREE.CapsuleGeometry(0.4, 1, 4, 8);
                const pMat = new THREE.MeshStandardMaterial({ color: 0xff0000 });
                players[id] = new THREE.Mesh(pGeo, pMat);
                scene.add(players[id]);
            }
            players[id].position.copy(data.pos);
        });

        // ブロック同期
        world.get('blocks').map().on((data, id) => {
            if(data) addBlock(data.x, data.y, data.z, data.type, false);
        });
    }

    function addBlock(x, y, z, type, sync = true) {
        const geo = new THREE.BoxGeometry(1, 1, 1);
        const mat = new THREE.MeshLambertMaterial({ color: blockTypes[type].color });
        const mesh = new THREE.Mesh(geo, mat);
        mesh.position.set(x, y, z);
        scene.add(mesh);
        blocks.push(mesh);
        if(sync) world.get('blocks').set({ x, y, z, type });
    }

    // --- モバイル操作 & 視点 ---
    let isTouching = false, prevX, prevY;
    document.addEventListener('touchstart', (e) => { 
        if(e.touches[0].clientX > window.innerWidth/2) {
            isTouching = true; prevX = e.touches[0].clientX; prevY = e.touches[0].clientY;
        }
    });
    document.addEventListener('touchmove', (e) => {
        if(!isTouching) return;
        const touch = e.touches[0];
        lon -= (touch.clientX - prevX) * 0.3;
        lat += (touch.clientY - prevY) * 0.3;
        lat = Math.max(-85, Math.min(85, lat));
        prevX = touch.clientX; prevY = touch.clientY;
    });
    document.addEventListener('touchend', () => isTouching = false);

    const joystick = document.getElementById('joystick-zone');
    const stick = document.getElementById('joystick-stick');
    joystick.addEventListener('touchmove', (e) => {
        const rect = joystick.getBoundingClientRect();
        const cx = rect.left + 60, cy = rect.top + 60;
        let dx = e.touches[0].clientX - cx, dy = e.touches[0].clientY - cy;
        const d = Math.min(Math.sqrt(dx*dx+dy*dy), 40);
        const angle = Math.atan2(dy, dx);
        dx = Math.cos(angle) * d; dy = Math.sin(angle) * d;
        stick.style.transform = `translate(${dx}px, ${dy}px)`;
        moveFwd = -dy/40; moveRight = dx/40;
    });
    joystick.addEventListener('touchend', () => {
        stick.style.transform = `translate(0,0)`;
        moveFwd = 0; moveRight = 0;
    });

    document.getElementById('btn-jump').ontouchstart = () => { if(camera.position.y <= 1.6) vY = 0.15; };
    document.getElementById('btn-action').ontouchstart = () => {
        const ray = new THREE.Raycaster();
        ray.setFromCamera(new THREE.Vector2(0,0), camera);
        const intersects = ray.intersectObjects(blocks);
        if(intersects.length > 0) {
            const p = intersects[0].object.position.clone().add(intersects[0].face.normal);
            addBlock(Math.round(p.x), Math.round(p.y), Math.round(p.z), selectedBlockType);
        }
    };

    // ホットバー切り替え
    document.querySelectorAll('.slot').forEach(s => {
        s.onclick = () => {
            document.querySelectorAll('.slot').forEach(x => x.classList.remove('active'));
            s.classList.add('active');
            selectedBlockType = parseInt(s.dataset.id);
        };
    });

    function animate() {
        requestAnimationFrame(animate);
        
        // 視点更新
        const phi = THREE.MathUtils.degToRad(90 - lat);
        const theta = THREE.MathUtils.degToRad(lon);
        const target = new THREE.Vector3().setFromSphericalCoords(1, phi, theta).add(camera.position);
        camera.lookAt(target);

        // 移動
        const fwd = new THREE.Vector3(); camera.getWorldDirection(fwd); fwd.y = 0; fwd.normalize();
        const rgt = new THREE.Vector3().crossVectors(camera.up, fwd).negate();
        camera.position.addScaledVector(fwd, moveFwd * 0.1);
        camera.position.addScaledVector(rgt, moveRight * 0.1);

        vY -= 0.008; camera.position.y += vY;
        if(camera.position.y < 1.6) { camera.position.y = 1.6; vY = 0; }

        // ネットワーク送信
        if(world) world.get('players').get(myId).put({ pos: camera.position });

        renderer.render(scene, camera);
    }
</script>
</body>
</html>

